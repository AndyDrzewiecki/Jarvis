# ── Core ──────────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
JARVIS_MODEL=gemma3:27b
JARVIS_FALLBACK_MODEL=qwen2.5:0.5b

# ── Feature Flags ─────────────────────────────────────────────────────────────
JARVIS_SPECIALISTS_ENABLED=true
JARVIS_ENGINES_ENABLED=false
JARVIS_PROCEDURAL_FASTPATH=false

# ── Location (for weather, events, AQI) ──────────────────────────────────────
JARVIS_HOME_ZIP=55401
JARVIS_HOME_LAT=44.9778
JARVIS_HOME_LON=-93.2650

# ── API Keys (all optional — engines gracefully degrade without them) ─────────
JARVIS_FRED_API_KEY=
JARVIS_GITHUB_TOKEN=
JARVIS_CONGRESS_API_KEY=
JARVIS_AIRNOW_API_KEY=
JARVIS_EVENTBRITE_TOKEN=
JARVIS_NPS_API_KEY=

# ── Tracked Assets ────────────────────────────────────────────────────────────
JARVIS_TRACKED_SYMBOLS=SPY,QQQ,BTC-USD

# ── RSS Feeds (comma-separated URLs) ─────────────────────────────────────────
JARVIS_NEWS_FEEDS=
JARVIS_GEOPOLITICAL_FEEDS=
JARVIS_LOCAL_FEEDS=
